# Copy this file to .env and fill in any keys you have.
# Artificial Analysis API key is required for live refreshes and daily automation.
AA_API_KEY=

# Optional for the OpenRouter models API. Leave blank if you do not need authenticated access.
OPENROUTER_API_KEY=

# Optional overrides used by the Makefile and wrapper scripts.
OUT=out/openrouter_model_pricing_performance.xlsx
CACHE_DIR=.cache_model_workbook
MAPPING_CSV=config/model_map.csv
DATA_DIR=data/latest
SITE_DATA_DIR=site/public/data/latest

# Optional base path override for GitHub Pages-style deployments.
# Leave blank for local dev or root-path hosting.
VITE_BASE_PATH=/openrouter-model-workbook-maintainer-v2/
